{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 28,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "dev-clang-debug",
            "displayName": "Dev Clang Debug",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_COMPILER": "clang++",
                "WHEELCACHE_ENABLE_ASAN": "OFF",
                "WHEELCACHE_ENABLE_UBSAN": "OFF",
                "WHEELCACHE_ENABLE_TSAN": "OFF",
                "WHEELCACHE_ENABLE_CLANG_TIDY": "ON"
            }
        },
        {
            "name": "dev-clang-asan",
            "displayName": "Dev Clang ASan+UBSan",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_COMPILER": "clang++",
                "WHEELCACHE_ENABLE_ASAN": "ON",
                "WHEELCACHE_ENABLE_UBSAN": "ON",
                "WHEELCACHE_ENABLE_TSAN": "OFF",
                "WHEELCACHE_ENABLE_CLANG_TIDY": "ON"
            }
        },
        {
            "name": "dev-clang-tsan",
            "displayName": "Dev Clang TSan",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_COMPILER": "clang++",
                "WHEELCACHE_ENABLE_ASAN": "OFF",
                "WHEELCACHE_ENABLE_UBSAN": "OFF",
                "WHEELCACHE_ENABLE_TSAN": "ON",
                "WHEELCACHE_ENABLE_CLANG_TIDY": "OFF"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_COMPILER": "clang++",
                "WHEELCACHE_ENABLE_ASAN": "OFF",
                "WHEELCACHE_ENABLE_UBSAN": "OFF",
                "WHEELCACHE_ENABLE_TSAN": "OFF",
                "WHEELCACHE_ENABLE_CLANG_TIDY": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "dev-clang-debug",
            "configurePreset": "dev-clang-debug"
        },
        {
            "name": "dev-clang-asan",
            "configurePreset": "dev-clang-asan"
        },
        {
            "name": "dev-clang-tsan",
            "configurePreset": "dev-clang-tsan"
        },
        {
            "name": "release",
            "configurePreset": "release"
        }
    ],
    "testPresets": [
        {
            "name": "dev-clang-debug",
            "configurePreset": "dev-clang-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "dev-clang-asan",
            "configurePreset": "dev-clang-asan",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "dev-clang-tsan",
            "configurePreset": "dev-clang-tsan",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
